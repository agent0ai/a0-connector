#chat-log {
    height: 1fr;
    border: solid $primary;
    padding: 1;
}

#message-input {
    dock: bottom;
    margin-top: 1;
    margin-bottom: 1;
    border: solid $primary;
}

HostInputScreen {
    align: center middle;
}

#host-box {
    width: 60%;
    min-width: 40;
    border: solid $primary;
    padding: 2;
    background: $panel;
}

#host-title {
    content-align: center middle;
    text-style: bold;
    margin-bottom: 1;
}

#host-description {
    margin-bottom: 1;
}

LoginScreen {
    align: center middle;
}

#login-box {
    width: 60%;
    min-width: 40;
    border: solid $primary;
    padding: 2;
    background: $panel;
}

#login-title {
    content-align: center middle;
    text-style: bold;
    margin-bottom: 1;
}

#login-error {
    color: $error;
    height: 1;
    margin-top: 1;
}

ChatListScreen {
    align: center middle;
}

#chat-list-panel {
    width: 80%;
    min-width: 40;
    max-height: 70%;
    border: solid $primary;
    padding: 1;
    background: $panel;
}

#chat-list-title {
    text-style: bold;
    margin-bottom: 1;
}

#chat-list-empty {
    color: $text-muted;
    height: 3;
    content-align: center middle;
}

#chat-list {
    height: 1fr;
    border: solid $primary;
}
