Screen {
    background: #17181a;
    layers: base status;
}

#chat-log {
    height: 1fr;
    padding: 0;
    background: #17181a;
    overflow-x: hidden;
    scrollbar-size: 1 1;
}

#chat-log > Static {
    margin-top: 1;
}

#message-input {
    margin-top: 0;
    margin-bottom: 0;
    border: round #555555;
    background: #17181a;
    padding: 0 1;
}

/* Subtle highlight while progress placeholder is shown (see WebUI .progress-active). */
#message-input.progress-active {
    border: round #777777;
}

#message-input:focus {
    border: round #777777;
}

#connection-status {
    layer: status;
    width: 100%;
    height: 1;
    content-align: right top;
    padding-right: 2;
    background: transparent;
    color: #444444;
}

Footer {
    background: #17181a;
}

HostInputScreen {
    align: center middle;
}

#host-box {
    width: 60%;
    min-width: 40;
    border: solid $primary;
    padding: 2;
    background: $panel;
}

#host-title {
    content-align: center middle;
    text-style: bold;
    margin-bottom: 1;
}

#host-description {
    margin-bottom: 1;
}

#host-url {
    margin-bottom: 1;
}

#host-btn,
#login-btn {
    width: 100%;
    height: 3;
}

LoginScreen {
    align: center middle;
}

#login-box {
    width: 60%;
    min-width: 40;
    border: solid $primary;
    padding: 2;
    background: $panel;
}

#username,
#password,
#save-credentials {
    width: 100%;
    margin-bottom: 1;
}

#login-btn {
    margin-top: 1;
}

#login-title {
    content-align: center middle;
    text-style: bold;
    margin-bottom: 1;
}

#login-error {
    color: $error;
    height: 1;
    margin-top: 1;
}

ChatListScreen {
    align: left top;
}

#chat-list-panel {
    width: 100%;
    min-width: 100%;
    max-height: 100%;
    padding: 1;
    scrollbar-size: 1 1;
}

#chat-list-title {
    text-style: bold;
    margin-bottom: 1;
}

#chat-list-empty {
    color: $text-muted;
    height: 3;
    content-align: center middle;
}

#chat-list {
    height: 1fr;
    border: solid $primary;
}
