Screen {
    background: #0b1119;
}

#chat-log {
    height: 1fr;
    border: round #0f6db8;
    padding: 1 1 0 1;
    background: #0f141b;
    overflow-x: hidden;
}

#status-bar {
    height: 2; /* border-top consumes one row at height:1 */
    padding: 0 1;
    background: #101a24;
    color: $text-muted;
    border-top: solid #0f6db8;
    overflow: hidden hidden;
}

#message-input {
    margin-top: 0;
    margin-bottom: 0;
    border: round #0f6db8;
    background: #0f141b;
    padding: 0 1;
}

#message-input:focus {
    border: round #00b4ff;
}

Footer {
    background: #101a24;
}

HostInputScreen {
    align: center middle;
}

#host-box {
    width: 60%;
    min-width: 40;
    border: solid $primary;
    padding: 2;
    background: $panel;
}

#host-title {
    content-align: center middle;
    text-style: bold;
    margin-bottom: 1;
}

#host-description {
    margin-bottom: 1;
}

#host-url {
    margin-bottom: 1;
}

#host-btn,
#login-btn {
    width: 100%;
    height: 3;
}

LoginScreen {
    align: center middle;
}

#login-box {
    width: 60%;
    min-width: 40;
    border: solid $primary;
    padding: 2;
    background: $panel;
}

#username,
#password,
#save-credentials {
    width: 100%;
    margin-bottom: 1;
}

#login-btn {
    margin-top: 1;
}

#login-title {
    content-align: center middle;
    text-style: bold;
    margin-bottom: 1;
}

#login-error {
    color: $error;
    height: 1;
    margin-top: 1;
}

ChatListScreen {
    align: center middle;
}

#chat-list-panel {
    width: 80%;
    min-width: 40;
    max-height: 70%;
    border: solid $primary;
    padding: 1;
    background: $panel;
}

#chat-list-title {
    text-style: bold;
    margin-bottom: 1;
}

#chat-list-empty {
    color: $text-muted;
    height: 3;
    content-align: center middle;
}

#chat-list {
    height: 1fr;
    border: solid $primary;
}
